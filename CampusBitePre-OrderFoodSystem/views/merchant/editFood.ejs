<!DOCTYPE html>
<html>
<head>
  <title><%= isEdit ? 'Edit Food' : 'Add Food' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/favicon.png?v=2">
  <link rel="shortcut icon" href="/favicon.png?v=2">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/foods">Manage Foods</a>
        <a class="cb-nav-link" href="/menu/<%= (food && food.merchant) ? food.merchant : '' %>">Menu</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Food editor</span>
        <h1><%= isEdit ? 'Edit Food Item' : 'Add Food Item' %></h1>
        <p class="cb-subtitle"><%= isEdit ? 'Update details and upload a new image if needed.' : 'Create a new food listing.' %></p>
      </div>
    </div>

  <form method="POST" action="<%= isEdit ? '/foods/' + food._id + '/edit' : '/foods/add' %>" enctype="multipart/form-data">

    <% if (isEdit && food.image) { %>
      <div>
        <img src="<%= food.image %>" alt="Food image" style="max-width: 200px; height: auto;" />
      </div>
      <br>
    <% } %>

    <label>Food Picture</label><br>
    <input type="file" name="image" accept="image/*">
    <br><br>

    <label>Name</label><br>
    <input type="text" name="name" value="<%= food.name %>" placeholder="Food Name" required>
    <br><br>

    <label>Price</label><br>
    <input type="number" name="price" value="<%= food.priceText || food.price %>" placeholder="Price" step="0.01" min="0.01" required>
    <br><br>

    <label>Category</label><br>
    <select id="categorySelect" name="category" required data-current="<%= food.category || '' %>">
      <option value="" disabled <%= !food.category ? "selected" : "" %>>Select category</option>
      <% (categories || []).forEach(function (cat) { %>
        <option value="<%= cat %>" <%= food.category === cat ? "selected" : "" %>><%= cat %></option>
      <% }) %>
      <option value="__custom__">Other (new category)</option>
    </select>
    <br><br>

    <label>New category (letters and spaces only)</label><br>
    <input id="categoryCustom" type="text" name="categoryCustom" value="" placeholder="New category" pattern="[A-Za-z ]+" title="Letters and spaces only">
    <br><br>

    <label>Description</label><br>
    <textarea name="description" placeholder="Description"><%= food.description || '' %></textarea>
    <br><br>

    <button type="submit"><%= isEdit ? 'Save Changes' : 'Add Food' %></button>
    <a class="ml-2 cb-btn cb-btn--ghost" href="/foods">Cancel</a>

  </form>

  </main>

  <script src="/js/cb-ui.js" defer></script>
  <script>
    (function () {
      var select = document.getElementById("categorySelect");
      var custom = document.getElementById("categoryCustom");
      if (!select || !custom) return;

      function syncCustomRequirement() {
        var isCustom = select.value === "__custom__";
        if (isCustom) {
          custom.required = true;
          custom.disabled = false;
        } else {
          custom.required = false;
          custom.disabled = true;
          custom.value = "";
        }
      }

      var current = select.getAttribute("data-current") || "";
      if (current && select.value === "") {
        select.value = "__custom__";
        custom.value = current;
      }

      syncCustomRequirement();
      select.addEventListener("change", syncCustomRequirement);
    })();
  </script>

</body>
</html>
