<!DOCTYPE html>
<html>
<head>
  <title>Shops</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/favicon.png?v=2">
  <link rel="shortcut icon" href="/favicon.png?v=2">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <section class="cb-hero cb-hero--split">
      <div>
        <span class="cb-kicker">Shops</span>
        <h1>Choose a Shop</h1>
        <p class="cb-subtitle">Search by name then view the menu.</p>
      </div>
      <div class="cb-hero-card">
        <div class="cb-hero-image">
          <span class="cb-hero-chip">Fresh today</span>
        </div>
        <div class="cb-hero-card-body">
          <p class="cb-card-title">Local favorites</p>
          <p class="cb-muted">Find shops with pickup-ready menus.</p>
          <div class="cb-card-meta">
            <span class="cb-badge">Pickup</span>
            <span class="cb-badge cb-badge--muted">New</span>
          </div>
        </div>
      </div>
    </section>

    <div class="cb-shell">
      <aside class="cb-sidebar">
        <div class="cb-sidecard">
          <h3 class="cb-side-title">Search</h3>
          <form class="cb-form" method="GET" action="/shops">
            <label>Search</label><br>
            <input
              type="text"
              name="search"
              placeholder="Search shop..."
              value="<%= search %>"
            >

            <br><br>
            <button type="submit">Apply</button>
          </form>
        </div>
      </aside>

      <section class="cb-main">
        <% if (!shops || shops.length === 0) { %>
          <div class="card cb-empty">
            <h3>No shops found</h3>
            <p class="cb-muted">Try a different search.</p>
          </div>
        <% } else { %>
          <div class="cb-grid">
            <% shops.forEach(shop => { %>
              <div class="cb-card">
                <% if (shop.profileImage) { %>
                  <img class="cb-card-media" src="<%= shop.profileImage %>" alt="<%= shop.username %>">
                <% } else { %>
                  <div class="cb-card-media"></div>
                <% } %>
                <div class="cb-card-body">
                  <p class="cb-card-title"><%= shop.username %></p>
                  <div class="cb-actions">
                    <a href="/menu/<%= shop._id %>"><button type="button">View Menu</button></a>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>