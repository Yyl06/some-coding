<!DOCTYPE html>
<html>
<head>
  <title>Your Shop Menu</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/foods">Manage Foods</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <%
      const menuBase = '/menu/' + merchantId;
      const searchValue = search || '';
      const searchQuery = searchValue ? '&search=' + encodeURIComponent(searchValue) : '';
      const allLink = menuBase + (searchValue ? '?search=' + encodeURIComponent(searchValue) : '');
    %>

    <section class="cb-hero cb-hero--split">
      <div>
        <span class="cb-kicker">Preview</span>
        <h1>Your Shop Menu</h1>
        <p class="cb-subtitle">Preview your menu like customers see it.</p>
        <div class="cb-hero-actions">
          <span class="cb-pill">Live preview</span>
          <span class="cb-pill">Customer view</span>
        </div>
      </div>
      <div class="cb-hero-card">
        <div class="cb-hero-image">
          <span class="cb-hero-chip">Merchant view</span>
        </div>
        <div class="cb-hero-card-body">
          <p class="cb-card-title">Featured board</p>
          <p class="cb-muted">Highlight your top dishes here.</p>
          <div class="cb-card-meta">
            <span class="cb-badge">Fast pickup</span>
            <span class="cb-badge cb-badge--muted">Ready status</span>
          </div>
        </div>
      </div>
    </section>

    <div class="cb-shell">
      <aside class="cb-sidebar">
        <div class="cb-sidecard">
          <h3 class="cb-side-title">Filter</h3>
          <form class="cb-form" method="GET" action="<%= menuBase %>">
            <label>Search</label><br>
            <input type="text" name="search" placeholder="Search food..." value="<%= searchValue %>">

            <br><br>

            <label>Category</label><br>
            <select name="category">
              <option value="">All Categories</option>
              <% (categories || []).forEach(function (cat) { %>
                <option value="<%= cat %>" <%= category === cat ? "selected" : "" %>>
                  <%= cat %>
                </option>
              <% }) %>
            </select>

            <br><br>
            <button type="submit">Apply filters</button>
            <a class="ml-2 cb-btn cb-btn--ghost" href="/dashboard">Back</a>
          </form>
        </div>

        <div class="cb-sidecard">
          <h3 class="cb-side-title">Quick categories</h3>
          <div class="cb-pill-list">
            <a class="cb-pill <%= !category ? 'cb-pill--active' : '' %>" href="<%= allLink %>">All</a>
            <% (categories || []).forEach(function (cat) { %>
              <a class="cb-pill <%= category === cat ? 'cb-pill--active' : '' %>" href="<%= menuBase + '?category=' + encodeURIComponent(cat) + searchQuery %>"><%= cat %></a>
            <% }) %>
          </div>
        </div>
      </aside>

      <section class="cb-main">
        <% if (!foods || foods.length === 0) { %>
          <div class="card cb-empty">
            <h3>No foods found.</h3>
            <p class="cb-muted">Try changing your search or category.</p>
          </div>
        <% } else { %>
          <div class="cb-grid">
            <% foods.forEach(food => { %>
              <div class="cb-card">
                <% if (food.image) { %>
                  <img class="cb-card-media" src="<%= food.image %>" alt="<%= food.name %>">
                <% } else { %>
                  <div class="cb-card-media"></div>
                <% } %>
                <div class="cb-card-body">
                  <p class="cb-card-title"><%= food.name %></p>
                  <p class="cb-card-meta">
                    <span class="cb-badge">RM <%= food.priceText %></span>
                    <span class="cb-badge cb-badge--muted"><%= food.category %></span>
                  </p>
                  <p class="cb-muted"><%= food.description %></p>
                  <p class="cb-muted">
                    <strong>Status:</strong>
                    <% if (food.availability) { %>
                      <span class="cb-badge">Available</span>
                    <% } else { %>
                      <span class="cb-badge cb-badge--muted">Unavailable</span>
                    <% } %>
                  </p>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
