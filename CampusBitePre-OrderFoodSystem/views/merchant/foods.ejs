<!DOCTYPE html>
<html>
<head>
  <title>Manage Foods</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/favicon.png?v=2">
  <link rel="shortcut icon" href="/favicon.png?v=2">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/menu/<%= user.id %>">Menu</a>
        <a class="cb-nav-link" href="/foods">Manage Foods</a>
        <a class="cb-nav-link" href="/orders">Orders</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Inventory</span>
        <h1>Manage Foods</h1>
        <p class="cb-subtitle">Logged in as <%= user.username %> (<%= user.role %>)</p>
      </div>
      <div class="cb-actions">
        <a href="/foods/add"><button type="button">Add Food</button></a>
        <a href="/dashboard"><button type="button">Back</button></a>
      </div>
    </div>

  <% if (!foods || foods.length === 0) { %>
    <div class="card cb-empty">
      <h3>No food items yet</h3>
      <p class="cb-muted">Add your first item to start selling.</p>
    </div>
  <% } else { %>

    <div class="cb-grid">
      <% foods.forEach(food => { %>
        <div class="cb-card">
          <% if (food.image) { %>
            <img class="cb-card-media" src="<%= food.image %>" alt="<%= food.name %>">
          <% } else { %>
            <div class="cb-card-media"></div>
          <% } %>

          <div class="cb-card-body">
            <p class="cb-card-title"><%= food.name %></p>

            <p class="cb-card-meta">
              <span class="cb-badge cb-badge--primary">RM <%= food.priceText %></span>
              <span class="cb-badge cb-badge--muted"><%= food.category %></span>
              <% if (food.availability) { %>
                <span class="cb-badge cb-badge--primary">Available</span>
              <% } else { %>
                <span class="cb-badge">Unavailable</span>
              <% } %>
            </p>

            <% if (user.role === 'admin') { %>
              <p class="cb-muted"><strong>Merchant:</strong> <%= food.merchant && food.merchant.username ? food.merchant.username : '' %></p>
            <% } %>

            <div class="cb-actions">
              <a href="/foods/<%= food._id %>/edit"><button type="button">Edit</button></a>

              <form class="inline-form" method="POST" action="/foods/<%= food._id %>/toggle">
                <button type="submit"><%= food.availability ? 'Mark Unavailable' : 'Mark Available' %></button>
              </form>

              <form class="inline-form" method="POST" action="/foods/<%= food._id %>/delete" onsubmit="return confirm('Delete this food item?');">
                <button type="submit">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

  <% } %>

  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
