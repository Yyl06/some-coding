<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/menu/<%= user.id %>">Menu</a>
        <a class="cb-nav-link" href="/foods">Manage Foods</a>
        <a class="cb-nav-link" href="/orders">Orders</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Dashboard</span>
        <h1>Merchant Dashboard</h1>
        <p class="cb-subtitle">Welcome, <%= user.username %></p>
      </div>
      <div class="cb-hero-actions">
        <a class="cb-btn cb-btn--ghost" href="/foods">Manage foods</a>
        <a class="cb-btn" href="/orders">View orders</a>
      </div>
    </div>

    <div class="cb-tile-grid">
      <div class="cb-tile">
        <h3>Your shop menu</h3>
        <p>Preview what customers see.</p>
        <div class="cb-actions">
          <a href="/menu/<%= user.id %>"><button type="button">View Menu</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Manage foods</h3>
        <p>Add, edit, and upload food images.</p>
        <div class="cb-actions">
          <a href="/foods"><button type="button">Open</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Orders</h3>
        <p>View pickup orders placed by customers.</p>
        <div class="cb-actions">
          <a href="/orders"><button type="button">View Orders</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Your account</h3>
        <p class="cb-muted">Email: <%= user.email %></p>
        <p class="cb-muted">Role: <%= user.role %></p>
        <div class="cb-actions">
          <a href="/auth/profile"><button type="button">Update Profile</button></a>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>