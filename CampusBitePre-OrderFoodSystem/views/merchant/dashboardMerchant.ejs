<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/menu/<%= user.id %>">Menu</a>
        <a class="cb-nav-link" href="/foods">Manage Foods</a>
        <a class="cb-nav-link" href="/orders">Orders</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <form action="/auth/logout" class="inline-form" onsubmit="return confirm('Logging out from this session?');">
          <button type="submit">Logout</button>
        </form>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Dashboard</span>
        <h1>Merchant Dashboard</h1>
        <p class="cb-subtitle">Welcome, <%= user.username %></p>
      </div>
      <div class="cb-hero-actions">
        <a class="cb-btn cb-btn--ghost" href="/foods">Manage foods</a>
        <a class="cb-btn" href="/orders">View orders</a>
      </div>
    </div>

    <section class="cb-scroll-section">
      <div class="cb-hero" style="padding: 16px 20px;">
        <div>
          <span class="cb-kicker">Today</span>
          <h2>Keep service smooth</h2>
          <p class="cb-subtitle">Swipe for quick actions and checks.</p>
        </div>
      </div>
      <div class="cb-scroll-row">
        <div class="cb-scroll-card">
          <strong>Incoming orders</strong>
          <p class="cb-muted">Confirm or reject orders quickly.</p>
          <a class="cb-btn" href="/orders">Open orders</a>
        </div>
        <div class="cb-scroll-card">
          <strong>Menu updates</strong>
          <p class="cb-muted">Keep your items and prices fresh.</p>
          <a class="cb-btn cb-btn--ghost" href="/foods">Manage foods</a>
        </div>
        <div class="cb-scroll-card">
          <strong>Daily report</strong>
          <p class="cb-muted">Track sales and pickup flow.</p>
          <a class="cb-btn cb-btn--ghost" href="/orders/reports/daily">View report</a>
        </div>
      </div>
    </section>

    <div class="cb-tile-grid">
      <div class="cb-tile">
        <h3>Your shop menu</h3>
        <p>Preview what customers see.</p>
        <div class="cb-actions">
          <a href="/menu/<%= user.id %>"><button type="button">View Menu</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Manage foods</h3>
        <p>Add, edit, and upload food images.</p>
        <div class="cb-actions">
          <a href="/foods"><button type="button">Open</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Orders</h3>
        <p>View pickup orders placed by customers.</p>
        <div class="cb-actions">
          <a href="/orders"><button type="button">View Orders</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Your account</h3>
        <p class="cb-muted">Email: <%= user.email %></p>
        <p class="cb-muted">Role: <%= user.role %></p>
        <div class="cb-actions">
          <a href="/auth/profile"><button type="button">Update Profile</button></a>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>