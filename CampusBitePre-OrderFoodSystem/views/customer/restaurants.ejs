<!DOCTYPE html>
<html>
<head>
  <title>Restaurants</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Dashboard</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">

  <div class="cb-hero">
    <div>
      <h1>Choose a Restaurant</h1>
      <p class="cb-subtitle">Search by name and filter by merchant type.</p>
    </div>
  </div>

  <% 
    const selectedType = (typeof type !== "undefined") ? type : "";
    const searchValue = (typeof search !== "undefined") ? search : "";
    const shopsList = (typeof shops !== "undefined" && Array.isArray(shops)) ? shops : [];
  %>

  <div class="cb-layout">
    <aside class="cb-sidebar">
      <form method="GET" action="/shops">
        <label>Search</label><br>
        <input
          type="text"
          name="search"
          placeholder="Search restaurant..."
          value="<%= searchValue %>"
        >

        <br><br>

        <label>Type</label><br>
        <select name="type">
          <option value="">All Types</option>

          <option value="Hawker Centre"
            <%= selectedType === "Hawker Centre" ? "selected" : "" %>>
            Hawker Centre
          </option>

          <option value="Cafe"
            <%= selectedType === "Cafe" ? "selected" : "" %>>
            Cafe
          </option>

          <option value="Desserts"
            <%= selectedType === "Desserts" ? "selected" : "" %>>
            Desserts
          </option>

          <option value="Beverages"
            <%= selectedType === "Beverages" ? "selected" : "" %>>
            Beverages
          </option>

          <option value="Other"
            <%= selectedType === "Other" ? "selected" : "" %>>
            Other
          </option>
        </select>

        <br><br>
        <button type="submit">Apply filters</button>
      </form>
    </aside>

    <section class="cb-main">
      <% if (!shopsList || shopsList.length === 0) { %>
        <div class="card cb-empty">
          <h3>No restaurants found</h3>
          <p class="cb-muted">Try changing your search or filters.</p>
        </div>
      <% } else { %>
        <div class="cb-grid">
          <% shopsList.forEach(shop => { %>
            <div class="cb-card">
              <% if (shop.profileImage) { %>
                <img class="cb-card-media" src="<%= shop.profileImage %>" alt="<%= shop.username %>">
              <% } else { %>
                <div class="cb-card-media"></div>
              <% } %>

              <div class="cb-card-body">
                <p class="cb-card-title"><%= shop.username %></p>
                <p class="cb-card-meta"><%= shop.merchantType || 'Restaurant' %></p>
                <div class="cb-actions">
                  <a href="/menu/<%= shop._id %>"><button type="button">View Menu</button></a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>

  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
