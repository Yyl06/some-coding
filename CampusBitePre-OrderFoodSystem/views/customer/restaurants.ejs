<!DOCTYPE html>
<html>
<head>
  <title>Restaurants</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">

  <section class="cb-hero cb-hero--split">
    <div>
      <span class="cb-kicker">Restaurants</span>
      <h1>Choose a Restaurant</h1>
      <p class="cb-subtitle">Search by name and filter by merchant type.</p>
      <div class="cb-hero-actions">
        <span class="cb-pill">Pickup ready</span>
        <span class="cb-pill">Pay on pickup</span>
      </div>
    </div>
    <div class="cb-hero-card">
      <div class="cb-hero-image">
        <span class="cb-hero-chip">New spots</span>
      </div>
      <div class="cb-hero-card-body">
        <p class="cb-card-title">Local favorites</p>
        <p class="cb-muted">Discover cafes, hawker stalls, and more.</p>
        <div class="cb-card-meta">
          <span class="cb-badge">Fast pickup</span>
          <span class="cb-badge cb-badge--muted">Nearby</span>
        </div>
      </div>
    </div>
  </section>

  <% 
    const selectedType = (typeof type !== "undefined") ? type : "";
    const searchValue = (typeof search !== "undefined") ? search : "";
    const shopsList = (typeof shops !== "undefined" && Array.isArray(shops)) ? shops : [];
    const typeOptions = ["Hawker Centre", "Cafe", "Desserts", "Beverages", "Other"];
    const searchQuery = searchValue ? "&search=" + encodeURIComponent(searchValue) : "";
  %>

  <div class="cb-shell">
    <aside class="cb-sidebar">
      <div class="cb-sidecard">
        <h3 class="cb-side-title">Filter</h3>
        <form class="cb-form" method="GET" action="/shops">
          <label>Search</label><br>
          <input
            type="text"
            name="search"
            placeholder="Search restaurant..."
            value="<%= searchValue %>"
          >

          <br><br>

          <label>Type</label><br>
          <select name="type">
            <option value="">All Types</option>
            <% typeOptions.forEach(function(option) { %>
              <option value="<%= option %>" <%= selectedType === option ? "selected" : "" %>><%= option %></option>
            <% }) %>
          </select>

          <br><br>
          <button type="submit">Apply filters</button>
        </form>
      </div>

      <div class="cb-sidecard">
        <h3 class="cb-side-title">Quick types</h3>
        <div class="cb-pill-list">
          <a class="cb-pill <%= !selectedType ? 'cb-pill--active' : '' %>" href="/shops<%= searchValue ? '?search=' + encodeURIComponent(searchValue) : '' %>">All</a>
          <% typeOptions.forEach(function(option) { %>
            <a class="cb-pill <%= selectedType === option ? 'cb-pill--active' : '' %>" href="/shops?type=<%= encodeURIComponent(option) %><%= searchQuery %>"><%= option %></a>
          <% }) %>
        </div>
      </div>
    </aside>

    <section class="cb-main">
      <% if (!shopsList || shopsList.length === 0) { %>
        <div class="card cb-empty">
          <h3>No restaurants found</h3>
          <p class="cb-muted">Try changing your search or filters.</p>
        </div>
      <% } else { %>
        <div class="cb-grid">
          <% shopsList.forEach(shop => { %>
            <div class="cb-card">
              <% if (shop.profileImage) { %>
                <img class="cb-card-media" src="<%= shop.profileImage %>" alt="<%= shop.username %>">
              <% } else { %>
                <div class="cb-card-media"></div>
              <% } %>

              <div class="cb-card-body">
                <p class="cb-card-title"><%= shop.username %></p>
                <p class="cb-card-meta"><%= shop.merchantType || 'Restaurant' %></p>
                <div class="cb-actions">
                  <a href="/menu/<%= shop._id %>"><button type="button">View Menu</button></a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>

  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
