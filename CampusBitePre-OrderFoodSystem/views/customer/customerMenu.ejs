<!DOCTYPE html>
<html>
<head>
  <title>Restaurant Menu</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/shops">Restaurants</a>
        <a class="cb-nav-link" href="/orders/checkout">Checkout (<%= typeof cartCount === 'number' ? cartCount : 0 %>)</a>
        <a class="cb-nav-link" href="/orders">My Orders</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <%
      const menuBase = merchantId ? '/menu/' + merchantId : '/menu';
      const searchValue = search || '';
      const searchQuery = searchValue ? '&search=' + encodeURIComponent(searchValue) : '';
      const allLink = menuBase + (searchValue ? '?search=' + encodeURIComponent(searchValue) : '');
    %>

    <section class="cb-hero cb-hero--split">
      <div>
        <span class="cb-kicker">Menu</span>
        <h1>Restaurant Menu</h1>
        <p class="cb-subtitle">Search foods and filter by category.</p>
        <div class="cb-hero-actions">
          <span class="cb-pill">Pickup only</span>
          <span class="cb-pill">Pay on pickup</span>
        </div>
      </div>
      <div class="cb-hero-card">
        <div class="cb-hero-image">
          <span class="cb-hero-chip">Chef picks</span>
        </div>
        <div class="cb-hero-card-body">
          <p class="cb-card-title">Hot today</p>
          <p class="cb-muted">Fresh batches updated by merchants.</p>
          <div class="cb-card-meta">
            <span class="cb-badge">Fast pickup</span>
            <span class="cb-badge cb-badge--muted">Student favorites</span>
          </div>
        </div>
      </div>
    </section>

    <div class="cb-shell">
      <aside class="cb-sidebar">
        <div class="cb-sidecard">
          <h3 class="cb-side-title">Filter</h3>
          <form class="cb-form" method="GET" action="<%= menuBase %>">
            <label>Search</label><br>
            <input type="text" name="search" placeholder="Search food..." value="<%= searchValue %>">

            <br><br>

            <label>Category</label><br>
            <select name="category">
              <option value="">All Categories</option>
              <% (categories || []).forEach(function (cat) { %>
                <option value="<%= cat %>" <%= category === cat ? "selected" : "" %>>
                  <%= cat %>
                </option>
              <% }) %>
            </select>

            <br><br>
            <button type="submit">Apply filters</button>
            <a class="ml-2 cb-btn cb-btn--ghost" href="/shops">Back</a>
          </form>
        </div>

        <div class="cb-sidecard">
          <h3 class="cb-side-title">Quick categories</h3>
          <div class="cb-pill-list">
            <a class="cb-pill <%= !category ? 'cb-pill--active' : '' %>" href="<%= allLink %>">All</a>
            <% (categories || []).forEach(function (cat) { %>
              <a class="cb-pill <%= category === cat ? 'cb-pill--active' : '' %>" href="<%= menuBase + '?category=' + encodeURIComponent(cat) + searchQuery %>"><%= cat %></a>
            <% }) %>
          </div>
        </div>
      </aside>

      <section class="cb-main">
        <% if (!foods || foods.length === 0) { %>
          <div class="card cb-empty">
            <h3>No foods found</h3>
            <p class="cb-muted">Try changing your search or category.</p>
          </div>
        <% } else { %>
          <div class="cb-grid">
            <% foods.forEach(food => { %>
              <div class="cb-card">
                <% if (food.image) { %>
                  <img class="cb-card-media" src="<%= food.image %>" alt="<%= food.name %>">
                <% } else { %>
                  <div class="cb-card-media"></div>
                <% } %>
                <div class="cb-card-body">
                  <p class="cb-card-title"><%= food.name %></p>
                  <p class="cb-card-meta">
                    <span class="cb-badge">RM <%= food.priceText %></span>
                    <span class="cb-badge cb-badge--muted"><%= food.category %></span>
                  </p>
                  <p class="cb-muted"><%= food.description %></p>
                  <div class="cb-muted">
                    <strong>Status:</strong>
                    <% if (food.availability) { %>
                      <span class="cb-badge">Available</span>
                    <% } else { %>
                      <span class="cb-badge cb-badge--muted">Unavailable</span>
                    <% } %>
                  </div>

                  <% if (food.availability) { %>
                    <form class="inline-form cb-qty-form" method="POST" action="/orders/cart/add">
                      <input type="hidden" name="foodId" value="<%= food._id %>">
                      <input type="hidden" name="merchantId" value="<%= merchantId %>">
                      <div class="cb-qty">
                        <button type="button" class="cb-qty-btn" data-qty-action="down" aria-label="Decrease quantity">-</button>
                        <input type="number" name="quantity" class="cb-qty-input" min="1" max="99" value="1">
                        <button type="button" class="cb-qty-btn" data-qty-action="up" aria-label="Increase quantity">+</button>
                      </div>
                      <input type="text" name="remark" class="cb-remark-input" placeholder="Add remarks (optional)">
                      <button type="submit">Add to cart</button>
                    </form>
                  <% } else { %>
                    <button type="button" disabled>Add to cart</button>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
