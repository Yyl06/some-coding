<!DOCTYPE html>
<html>
<head>
  <title>Restaurant Menu</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <h1>Restaurant Menu</h1>

  <a href="/shops">
    <button type="button" onclick="location.href='/shops'">Back to Restaurants</button>
  </a>

  <form method="GET" action="<%= merchantId ? '/menu/' + merchantId : '/menu' %>">
    <input type="text" name="search" placeholder="Search food..." value="<%= search %>">

    <select name="category">
      <option value="">All Categories</option>

      <option value="Rice"
        <%= category === "Rice" ? "selected" : "" %>>
        Rice
      </option>

      <option value="Drink"
        <%= category === "Drink" ? "selected" : "" %>>
        Drink
      </option>

      <option value="Snack"
        <%= category === "Snack" ? "selected" : "" %>>
        Snack
      </option>
    </select>

    <button type="submit">Search</button>
  </form>

  <% foods.forEach(food => { %>
    <div class="card">
      <h2><%= food.name %></h2>
      <% if (food.image) { %>
        <img src="<%= food.image %>" alt="<%= food.name %>" style="max-width: 240px; height: auto;" />
      <% } %>
      <p>Price: RM <%= food.price %></p>
      <p>Category: <%= food.category %></p>
      <p><%= food.description %></p>
    </div>
  <% }) %>

</body>
</html>
