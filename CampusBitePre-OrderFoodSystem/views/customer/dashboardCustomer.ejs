<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="is-home">

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/shops">Restaurants</a>
        <a class="cb-nav-link" href="/orders/checkout">Checkout (<%= typeof cartCount === 'number' ? cartCount : 0 %>)</a>
        <a class="cb-nav-link" href="/orders">My Orders</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Dashboard</span>
        <h1>Customer Dashboard</h1>
        <p class="cb-subtitle">Welcome, <%= user.username %></p>
      </div>
      <div class="cb-hero-actions">
        <a class="cb-btn cb-btn--ghost" href="/shops">Browse restaurants</a>
        <a class="cb-btn" href="/orders/checkout">Checkout</a>
      </div>
    </div>

    <div class="cb-tile-grid">
      <div class="cb-tile">
        <h3>Choose restaurant</h3>
        <p>Browse merchants and view menus.</p>
        <div class="cb-actions">
          <a href="/shops"><button type="button">Browse</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Your orders</h3>
        <p>Pickup orders with pay-on-pickup checkout.</p>
        <div class="cb-actions">
          <a href="/orders"><button type="button">View Orders</button></a>
          <a href="/orders/checkout"><button type="button">Checkout</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Your account</h3>
        <p class="cb-muted">Email: <%= user.email %></p>
        <p class="cb-muted">Role: <%= user.role %></p>
        <div class="cb-actions">
          <a href="/auth/profile"><button type="button">Edit Profile</button></a>
        </div>
      </div>

      <div class="cb-tile">
        <h3>Sign out</h3>
        <p>End your current session safely.</p>
        <div class="cb-actions">
          <a href="/auth/logout"><button type="button">Logout</button></a>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>