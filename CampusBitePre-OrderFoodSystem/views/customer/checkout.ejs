<!DOCTYPE html>
<html>
<head>
  <title>Checkout</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/shops">Restaurants</a>
        <a class="cb-nav-link" href="/orders">My Orders</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Checkout</span>
        <h1>Checkout</h1>
        <p class="cb-subtitle">
          Pickup only • Payment: Pay on pickup
          <% if (merchant && merchant.username) { %>
            • Merchant: <strong><%= merchant.username %></strong>
          <% } %>
        </p>
      </div>
      <div class="cb-actions">
        <button type="button" class="cb-btn cb-btn--ghost" onclick="history.back()">Back</button>
        <a href="/shops"><button type="button">Continue browsing</button></a>
        <form class="inline-form" method="POST" action="/orders/cart/clear" onsubmit="return confirm('Clear your cart?');">
          <button type="submit">Clear cart</button>
        </form>
      </div>
    </div>

    <div class="cb-card cb-table-card">
      <h3>Order summary</h3>
      <div class="cb-table-wrap">
        <table class="cb-table" border="1" cellpadding="8" cellspacing="0">
        <thead>
          <tr>
            <th>Item</th>
            <th>Unit</th>
            <th>Qty</th>
            <th>Total</th>
            <th>Update</th>
            <th>Delete</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(line => { %>
            <tr>
              <td>
                <strong><%= line.name %></strong>
                <div class="cb-muted"><%= line.category %></div>
              </td>
              <td>RM <%= line.unitPrice.toFixed(2) %></td>
              <td>
                <input
                  type="number"
                  name="quantity"
                  min="0"
                  max="99"
                  value="<%= line.quantity %>"
                  style="width: 90px;"
                  form="update-<%= line.foodId %>"
                >
              </td>
              <td>RM <%= line.lineTotal.toFixed(2) %></td>
              <td>
                <form class="inline-form" method="POST" action="/orders/cart/update" id="update-<%= line.foodId %>">
                  <input type="hidden" name="foodId" value="<%= line.foodId %>">
                  <button type="submit">Save</button>
                </form>
              </td>
              <td>
                <form class="inline-form" method="POST" action="/orders/cart/delete" onsubmit="return confirm('Remove this item?');">
                  <input type="hidden" name="foodId" value="<%= line.foodId %>">
                  <button type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
        </table>
      </div>

      <hr>

      <div class="cb-actions" style="justify-content: space-between;">
        <div>
          <p class="cb-muted">Customer: <strong><%= user.username %></strong></p>
          <p class="cb-muted">Payment method: <strong>Pay on pickup</strong></p>
          <p class="cb-muted">Fulfillment: <strong>Pickup</strong></p>
        </div>
        <div style="text-align: right;">
          <p><strong>Grand total:</strong> RM <%= total.toFixed(2) %></p>
          <form class="inline-form" method="POST" action="/orders/checkout" onsubmit="return confirm('Place this order?');">
            <button type="submit">Place order</button>
          </form>
        </div>
      </div>

    </div>

  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
