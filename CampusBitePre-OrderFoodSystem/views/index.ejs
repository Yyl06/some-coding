<!DOCTYPE html>
<html>
<head>
    <title>CampusBite</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="is-home">

    <header class="cb-topbar">
        <div class="cb-topbar-inner">
            <a class="cb-brand" href="/"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
            <nav class="cb-nav">
                <a class="cb-nav-link" href="/">Home</a>
                <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
                <a class="cb-nav-link" href="/auth/login">Login</a>
                <a class="cb-nav-link cb-nav-link--primary" href="/auth/register">Register</a>
            </nav>
        </div>
    </header>

    <main class="page">
        <section class="cb-hero cb-hero--split">
            <div>
                <span class="cb-kicker">CampusBite</span>
                <h1>Pre-order campus favorites in minutes.</h1>
                <p class="cb-subtitle">Fresh menus, quick pickup, and a smoother lunchtime rush.</p>
                <div class="cb-hero-actions">
                    <a class="cb-btn" href="/auth/register">Start ordering</a>
                    <a class="cb-btn cb-btn--ghost" href="/auth/login">Sign in</a>
                </div>
                <div class="cb-hero-stats">
                    <div class="cb-stat">
                        <strong>60+</strong>
                        <span>daily dishes</span>
                    </div>
                    <div class="cb-stat">
                        <strong>15m</strong>
                        <span>average pickup</span>
                    </div>
                    <div class="cb-stat">
                        <strong>100%</strong>
                        <span>pay on pickup</span>
                    </div>
                </div>
            </div>
            <div class="cb-hero-card">
                <div class="cb-hero-image">
                    <span class="cb-hero-chip">Best offer</span>
                </div>
                <div class="cb-hero-card-body">
                    <p class="cb-card-title">Italian Veg Sandwich</p>
                    <p class="cb-muted">Toasted, fresh, and ready in a flash.</p>
                    <div class="cb-card-meta">
                        <span class="cb-badge">RM 16.50</span>
                        <span class="cb-badge cb-badge--muted">Pickup</span>
                    </div>
                </div>
            </div>
        </section>

        <div class="cb-tile-grid">
            <div class="cb-tile">
                <h3>Browse restaurants</h3>
                <p>Find merchants by type, location, and vibe.</p>
            </div>
            <div class="cb-tile">
                <h3>View menus</h3>
                <p>Search foods and filter by category instantly.</p>
            </div>
            <div class="cb-tile">
                <h3>Pickup ready</h3>
                <p>Skip queues with pay-on-pickup ordering.</p>
            </div>
        </div>
    </main>

    <script src="/js/cb-ui.js" defer></script>

</body>
</html>