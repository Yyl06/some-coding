<!DOCTYPE html>
<html>
<head>
  <title>Admin Reports</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/favicon.png?v=2">
  <link rel="shortcut icon" href="/favicon.png?v=2">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/auth/manageUser">Users</a>
        <a class="cb-nav-link" href="/orders">Orders</a>
        <a class="cb-nav-link" href="/orders/reports/admin">Reports</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Admin</span>
        <h1>Sales & Usage Reports</h1>
        <p class="cb-subtitle">Daily summary for <strong><%= dateValue %></strong>.</p>
      </div>
      <div class="cb-actions">
        <form class="inline-form" method="GET" action="/orders/reports/admin">
          <input type="date" name="date" value="<%= dateValue %>" max="<%= todayValue %>">
          <button type="submit">View date</button>
        </form>
      </div>
    </div>

    <div class="cb-grid cb-grid--2" style="margin-top: 18px;">
      <div class="cb-card">
        <div class="cb-card-body">
          <h3>Selected date</h3>
          <p class="cb-muted">Orders: <strong><%= ordersForDate %></strong></p>
          <p class="cb-muted">Revenue: <strong>RM <%= revenueForDate %></strong></p>
          <p class="cb-muted">Date range uses Malaysia/Singapore time.</p>
        </div>
      </div>
      <div class="cb-card">
        <div class="cb-card-body">
          <h3>All-time totals</h3>
          <p class="cb-muted">Total orders: <strong><%= totalOrders %></strong></p>
          <p class="cb-muted">Total revenue: <strong>RM <%= totalRevenue %></strong></p>
          <p class="cb-muted">Total users: <strong><%= totalUsers %></strong></p>
          <p class="cb-muted">Students: <strong><%= totalStudents %></strong></p>
          <p class="cb-muted">Merchants: <strong><%= totalMerchants %></strong></p>
        </div>
      </div>
    </div>

    <div class="cb-card" style="margin-top: 18px;">
      <div class="cb-card-body">
        <h3>System data</h3>
        <p class="cb-muted">Use the Users and Orders pages to edit or correct records.</p>
      </div>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
