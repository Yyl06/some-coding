<!DOCTYPE html>
<html>
<head>
  <title>Edit User</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <a class="cb-nav-link" href="/auth/manageUser">Users</a>
        <a class="cb-nav-link" href="/orders">Orders</a>
        <a class="cb-nav-link" href="/auth/profile">Profile</a>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">User editor</span>
        <h1>Edit User</h1>
        <p class="cb-subtitle">Update account info, role, and (optional) password.</p>
      </div>
      <div class="cb-actions">
        <a href="/auth/manageUser"><button type="button">Back to list</button></a>
      </div>
    </div>

    <div class="cb-shell">
      <aside class="cb-sidebar">
        <div class="cb-sidecard">
          <h3 class="cb-side-title">User summary</h3>
          <p class="cb-muted">Username: <strong><%= editUser.username %></strong></p>
          <p class="cb-muted">Email: <strong><%= editUser.email %></strong></p>
          <p class="cb-muted">Role: <strong><%= editUser.role %></strong></p>
          <p class="cb-muted">Merchant type: <strong><%= editUser.merchantType || 'N/A' %></strong></p>
        </div>

        <div class="cb-sidecard">
          <h3 class="cb-side-title">Shortcuts</h3>
          <div class="cb-pill-list">
            <a class="cb-pill" href="/dashboard">Dashboard</a>
            <a class="cb-pill" href="/auth/manageUser">Users</a>
            <a class="cb-pill" href="/orders">Orders</a>
            <a class="cb-pill" href="/auth/profile">Profile</a>
          </div>
        </div>
      </aside>

      <section class="cb-main">
        <div class="cb-card">
          <div class="cb-card-body">
            <form class="cb-form" method="POST" action="/auth/users/<%= editUser._id %>/edit">
              <label>Username</label><br>
              <input type="text" name="username" value="<%= editUser.username %>" required>

              <br><br>

              <label>Email</label><br>
              <input type="email" name="email" value="<%= editUser.email %>" required>

              <br><br>

              <label>Role</label><br>
              <select name="role" required>
                <option value="student" <%= editUser.role === 'student' ? 'selected' : '' %>>student</option>
                <option value="merchant" <%= editUser.role === 'merchant' ? 'selected' : '' %>>merchant</option>
                <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>admin</option>
              </select>

              <br><br>

              <label>Merchant Type (only if role = merchant)</label><br>
              <input type="text" name="merchantType" value="<%= editUser.merchantType || '' %>" placeholder="e.g. Cafe">

              <br><br>

              <label>New Password (leave blank to keep current)</label><br>
              <input type="password" name="password" value="" placeholder="••••••••">

              <br><br>

              <div class="cb-actions">
                <button type="submit">Save changes</button>
                <a class="cb-btn cb-btn--ghost" href="/auth/manageUser">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </section>
    </div>

  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>
