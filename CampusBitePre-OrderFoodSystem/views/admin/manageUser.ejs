<!DOCTYPE html>
<html>
    <head>
        <title>User List</title>
        <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/favicon.png?v=2">
  <link rel="shortcut icon" href="/favicon.png?v=2">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
    </head>

    <body>
                <header class="cb-topbar">
                    <div class="cb-topbar-inner">
                        <a class="cb-brand" href="/dashboard"><img src="/images/foods/campusbite_logo.png" alt="CampusBite" class="cb-brand-logo"></a>
                        <nav class="cb-nav">
                            <a class="cb-nav-link" href="/dashboard">Home</a>
                            <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
                            <a class="cb-nav-link" href="/auth/manageUser">Users</a>
                            <a class="cb-nav-link" href="/orders">Orders</a>
                            <a class="cb-nav-link" href="/auth/profile">Profile</a>
                            <a class="cb-nav-link" href="/auth/logout">Logout</a>
                        </nav>
                    </div>
                </header>

                <main class="page">
                    <div class="cb-hero">
                        <div>
                            <span class="cb-kicker">Users</span>
                            <h1>Users List</h1>
                            <p class="cb-subtitle">Manage users in the database.</p>
                        </div>
                        <div class="cb-actions">
                            <a href="/auth/admin/users/add"><button type="button">+ Add User</button></a>
                            <a href="/dashboard"><button type="button">Back</button></a>
                        </div>
                    </div>

                    <div class="cb-shell">
                        <aside class="cb-sidebar">
                            <div class="cb-sidecard">
                                <h3 class="cb-side-title">Summary</h3>
                                <p class="cb-muted">Total users: <strong><%= users ? users.length : 0 %></strong></p>
                            </div>

                            <div class="cb-sidecard">
                                <h3 class="cb-side-title">Shortcuts</h3>
                                <div class="cb-pill-list">
                                    <a class="cb-pill" href="/dashboard">Dashboard</a>
                                    <a class="cb-pill cb-pill--active" href="/auth/manageUser">Users</a>
                                    <a class="cb-pill" href="/orders">Orders</a>
                                    <a class="cb-pill" href="/auth/profile">Profile</a>
                                </div>
                            </div>
                        </aside>

                        <section class="cb-main">
                            <% if(!users || users.length === 0){ %>
                                <div class="card cb-empty">
                                    <h3>No users found</h3>
                                    <p class="cb-muted">Create an account first, then refresh.</p>
                                </div>
                            <% } else { %>
                                <div class="card cb-table-card">
                                    <div class="cb-table-wrap">
                                        <table class="cb-table" border="1" cellpadding="8" cellspacing="0">
                                        <thead>
                                            <tr>
                                                <th>Username</th>
                                                <th>Email</th>
                                                <th>Role</th>
                                                <th>Merchant Type</th>
                                                <th>Created At</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% users.forEach(line => { %>
                                                <tr>
                                                    <td><strong><%= line.username %></strong></td>
                                                    <td><%= line.email %></td>
                                                    <td><%= line.role %></td>
                                                    <td><%= line.merchantType || '' %></td>
                                                                                                        <td>
                                                                                                            <% if (line.createdAt) { %>
                                                                                                                <time class="js-local-time" datetime="<%= new Date(line.createdAt).toISOString() %>">
                                                                                                                    <%= new Date(line.createdAt).toLocaleString() %>
                                                                                                                </time>
                                                                                                            <% } %>
                                                                                                        </td>
                                                    <td>
                                                        <a href="/auth/users/<%= line._id %>/edit"><button type="button">Edit</button></a>
                                                        <form class="inline-form" method="POST" action="/auth/users/<%= line._id %>/delete" onsubmit="return confirm('Delete this user?');">
                                                            <button type="submit">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                        </table>
                                    </div>
                                </div>
                            <% } %>
                        </section>
                    </div>
                </main>

                <script src="/js/cb-ui.js" defer></script>
    </body>
</html>