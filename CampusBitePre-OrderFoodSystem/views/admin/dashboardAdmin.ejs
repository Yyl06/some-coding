<!DOCTYPE html>
<html>
<head>
	<title>Dashboard</title>
	<link rel="stylesheet" href="/css/style.css">
</head>
<body>

	<header class="cb-topbar">
		<div class="cb-topbar-inner">
			<a class="cb-brand" href="/dashboard">CampusBite</a>
			<nav class="cb-nav">
				<a class="cb-nav-link" href="/dashboard">Home</a>
				<button type="button" class="cb-nav-link" onclick="history.back()">Back</button>
				<a class="cb-nav-link" href="/auth/manageUser">Users</a>
				<a class="cb-nav-link" href="/orders">Orders</a>
				<a class="cb-nav-link" href="/auth/profile">Profile</a>
				<a class="cb-nav-link" href="/auth/logout">Logout</a>
			</nav>
		</div>
	</header>

	<main class="page">
		<div class="cb-hero">
			<div>
				<span class="cb-kicker">Admin</span>
				<h1>Admin Dashboard</h1>
				<p class="cb-subtitle">Welcome, <%= user.username %></p>
			</div>
			<div class="cb-hero-actions">
				<a class="cb-btn cb-btn--ghost" href="/auth/manageUser">Manage users</a>
				<a class="cb-btn" href="/auth/profile">Profile</a>
			</div>
		</div>

		<div class="cb-shell">
			<aside class="cb-sidebar">
				<div class="cb-sidecard">
					<h3 class="cb-side-title">Account</h3>
					<p class="cb-muted">Email: <strong><%= user.email %></strong></p>
					<p class="cb-muted">Role: <strong><%= user.role %></strong></p>
					<div class="cb-actions">	
						<a class="cb-btn cb-btn--ghost" href="/auth/profile">Profile</a>
						<a class="cb-btn" href="/auth/logout">Logout</a>
					</div>
				</div>

				<div class="cb-sidecard">
					<h3 class="cb-side-title">Shortcuts</h3>
					<div class="cb-pill-list">
						<a class="cb-pill" href="/auth/manageUser">Users</a>
						<a class="cb-pill" href="/orders">Orders</a>
					</div>
				</div>
			</aside>

			<section class="cb-main">
				<div class="cb-tile-grid">
					<div class="cb-tile">
						<h3>Users List</h3>
						<p>Lists and manages users in the database.</p>
						<div class="cb-actions">
							<a href="/auth/manageUser"><button type="button">Show</button></a>
						</div>
					</div>

					<div class="cb-tile">
						<h3>Orders</h3>
						<p>Review all customer and merchant orders.</p>
						<div class="cb-actions">
							<a href="/orders"><button type="button">Open</button></a>
						</div>
					</div>

					<div class="cb-tile">
						<h3>Session</h3>
						<p>Sign out of the admin dashboard.</p>
						<div class="cb-actions">
							<a href="/auth/logout"><button type="button">Logout</button></a>
						</div>
					</div>
				</div>
			</section>
		</div>
	</main>

	<script src="/js/cb-ui.js" defer></script>

</body>
</html>
