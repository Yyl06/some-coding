<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/auth/register">Register</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-auth">
      <section class="cb-auth-hero">
        <span class="cb-kicker">CampusBite</span>
        <h1>Welcome back.</h1>
        <p class="cb-subtitle">Pick up favorites fast and fresh.</p>
        <div class="cb-pill-list">
          <span class="cb-pill">Pickup only</span>
          <span class="cb-pill">Pay on pickup</span>
          <span class="cb-pill">No waiting</span>
        </div>
      </section>

      <section class="cb-auth-form">
        <div class="cb-card">
          <form class="cb-form" action="/auth/login" method="POST">
            <label>Username / Email</label><br>
            <input type="text" name="identifier" placeholder="Username/Email" required />
            <br><br>

            <label>Password</label><br>
            <input type="password" name="password" placeholder="Password" required />
            <br><br>

            <button type="submit">Login</button>
            <p class="cb-muted" style="margin-top: 10px;"><a href="/auth/forgotPassword">Forgot Password?</a></p>
            <p class="cb-muted" style="margin-top: 10px;">Don't have an account? <a href="/auth/register">Register here</a></p>
          </form>
        </div>
      </section>
    </div>
  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>