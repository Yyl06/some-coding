<!DOCTYPE html>
<html>
<head>
  <title>Register</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/auth/login">Login</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <h1>Register</h1>
        <p class="cb-subtitle">Create your account to start ordering.</p>
      </div>
    </div>

    <form action="/auth/register" method="POST">
      <label>Username</label><br>
      <input type="text" name="username" placeholder="Username" required />
      <br><br>

      <label>Email</label><br>
      <input type="email" name="email" placeholder="Email" required />
      <br><br>

      <label>Password</label><br>
      <input type="password" name="password" placeholder="Password" required />
      <br><br>

      <label>Account type</label><br>
      <select name="role" id="roleSelect">
        <option value="student">Student</option>
        <option value="merchant">Merchant</option>
      </select>

      <br><br>

      <div id="merchantTypeWrap" style="display: none;">
        <label>Merchant type (optional)</label><br>
        <select name="merchantType" id="merchantTypeSelect" disabled>
          <option value="">Select type</option>
          <option value="Hawker Centre">Hawker Centre</option>
          <option value="Cafe">Cafe</option>
          <option value="Desserts">Desserts</option>
          <option value="Beverages">Beverages</option>
          <option value="Other">Other</option>
        </select>

        <br><br>
      </div>

      <button type="submit">Register</button>
      <a class="ml-2" href="/auth/login">Go to Login</a>
    </form>
  </main>

  <script>
    const roleSelect = document.getElementById("roleSelect");
    const merchantTypeWrap = document.getElementById("merchantTypeWrap");
    const merchantTypeSelect = document.getElementById("merchantTypeSelect");

    function syncMerchantTypeVisibility() {
      const isMerchant = roleSelect.value === "merchant";
      merchantTypeWrap.style.display = isMerchant ? "block" : "none";
      merchantTypeSelect.disabled = !isMerchant;

      if (!isMerchant) {
        merchantTypeSelect.value = "";
      }
    }

    roleSelect.addEventListener("change", syncMerchantTypeVisibility);
    syncMerchantTypeVisibility();
  </script>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>