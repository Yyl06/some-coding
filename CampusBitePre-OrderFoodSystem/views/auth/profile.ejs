<!DOCTYPE html>
<html>
<head>
  <title>Profile</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="cb-topbar">
    <div class="cb-topbar-inner">
      <a class="cb-brand" href="/dashboard">CampusBite</a>
      <nav class="cb-nav">
        <a class="cb-nav-link" href="/dashboard">Home</a>
        <button type="button" class="cb-nav-link cb-nav-link--back" onclick="history.back()">Back</button>
        <% if (user && user.role === 'merchant') { %>
          <a class="cb-nav-link" href="/foods">Manage Foods</a>
          <a class="cb-nav-link" href="/menu/<%= user.id %>">Menu</a>
        <% } %>
        <% if (user && user.role === 'student') { %>
          <a class="cb-nav-link" href="/shops">Restaurants</a>
        <% } %>
        <a class="cb-nav-link" href="/auth/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <div class="cb-hero">
      <div>
        <span class="cb-kicker">Account</span>
        <h1>My Profile</h1>
        <p class="cb-subtitle">Update your details and profile picture.</p>
      </div>
    </div>

  <div class="cb-grid cb-grid--2">
    <div class="cb-card">
      <div class="cb-card-body">
        <h3>Profile picture</h3>
        <% if (user.profileImage) { %>
          <img src="<%= user.profileImage %>" alt="Profile picture" style="max-width: 180px; height: auto; border-radius: 16px;" />
          <br>
        <% } %>

        <form class="cb-form" method="POST" action="/auth/profile/image" enctype="multipart/form-data">
          <label>Upload Profile Picture</label><br>
          <input type="file" name="profileImage" accept="image/*" required>
          <br><br>
          <button type="submit">Upload Picture</button>
        </form>
      </div>
    </div>

    <div class="cb-card">
      <div class="cb-card-body">
        <h3>Account details</h3>
        <form class="cb-form" method="POST" action="/auth/profile">
          <label>Username</label><br>
          <input type="text" name="username" value="<%= user.username %>" required>
          <br><br>

          <label>Email</label><br>
          <input type="email" name="email" value="<%= user.email %>" required>
          <br><br>

          <label>New password</label><br>
          <input type="password" name="password" placeholder="New password" required />
          <br><br>

          <label>Confirm password</label><br>
          <input type="password" name="confirmPassword" placeholder="Confirm password" required />
          <br><br>
          
          <button type="submit">Update Profile</button>
        </form>
      </div>
    </div>
  </div>

  </main>

  <script src="/js/cb-ui.js" defer></script>

</body>
</html>